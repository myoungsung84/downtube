{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/app/**/*",
    "src/renderer/app/**/*.tsx",
    "src/preload/*.d.ts",
    "src/types/**/*",
    "src/libs/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "paths": {
      "@renderer/*": ["./src/renderer/app/*"],
      "@assets/*": ["./src/renderer/assets/*"],
      "@src/*": ["./src/*"],
      "@libs/*": ["./src/libs/*"]
    }
  }
}
