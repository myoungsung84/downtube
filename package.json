{
  "name": "downtube",
  "version": "1.0.5",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write . && eslint --fix .",
    "lint": "eslint .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "tools:ensure": "bash scripts/build-tools/ensure-tools.sh",
    "build": "bash scripts/build-tools/build.sh",
    "clean": "bash scripts/build-tools/build-clean.sh",
    "build:win": "bash scripts/build-tools/build-win.sh",
    "build:mac": "bash scripts/build-tools/build-mac.sh",
    "release:win": "bash scripts/release-tools/release-win.sh",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.shining.downtube",
    "productName": "Downtube",
    "icon": "assets/app-icon.ico",
    "mac": {
      "icon": "assets/app-icon.icns"
    },
    "files": [
      "out/**",
      "bin/**",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.0.2",
    "axios": "^1.8.4",
    "dayjs": "^1.11.20",
    "electron-log": "^5.3.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "fast-glob": "^3.3.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "lodash": "^4.17.21",
    "react-router-dom": "^7.5.2",
    "tree-kill": "^1.2.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/ffprobe-static": "^2.0.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.6"
  }
}
